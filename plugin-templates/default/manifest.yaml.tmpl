# Plugin Manifest Template
# Domain: {{.Domain}}
# Generated by: cto plugin create

domain: {{.Domain}}
version: "0.1.0"
display_name: "{{.DisplayName}}"
description: |
  Custom advisory board for {{.Domain}} domain.
  Edit this description to explain your domain's focus.

# Plugin metadata
author: "{{.Author}}"
license: "MIT"
min_cli_version: "1.0.0"

# Facilitator (Discovery Coach)
# The facilitator guides users through problem articulation before
# escalating to the full advisory board.
facilitator:
  id: "facilitator"
  name: "Jordan"
  role: "Discovery Coach"
  emoji: "💭"
  color: "141"
  thinking_style: "Socratic questioning to draw out the full picture"
  greeting_prompt: |
    Hello! I'm Jordan, your discovery coach. I'm here to help you
    articulate your challenge before we bring in the advisory board.

    What {{.Domain}} challenge are you facing today?

# Core Advisors (Always Available)
# These advisors form the permanent panel for this domain.
core_advisors:
  - id: "expert-1"
    name: "Expert One"
    role: "Strategic Advisor"
    emoji: "🎯"
    color: "39"
    thinking_style: "Long-term strategic perspective, focused on outcomes"
    background: |
      20+ years of experience in {{.Domain}}.
      Known for strategic thinking and outcome-focused advice.
    priorities:
      - Long-term impact
      - Strategic alignment
      - Resource optimization
    catch_phrases:
      - "What's the 10-year view here?"
      - "How does this align with your goals?"

  - id: "expert-2"
    name: "Expert Two"
    role: "Technical Advisor"
    emoji: "🔧"
    color: "208"
    thinking_style: "Practical, implementation-focused, detail-oriented"
    background: |
      Hands-on practitioner with deep technical expertise.
      Focus on feasibility and execution excellence.
    priorities:
      - Feasibility
      - Best practices
      - Risk mitigation
    catch_phrases:
      - "Let's look at the practical implications"
      - "Have you considered..."

  - id: "expert-3"
    name: "Expert Three"
    role: "Risk Advisor"
    emoji: "🛡️"
    color: "196"
    thinking_style: "Risk-aware, protective, cautious but constructive"
    background: |
      Specializes in identifying and mitigating risks.
      Balances caution with enabling progress.
    priorities:
      - Risk identification
      - Compliance
      - Protection
    catch_phrases:
      - "What could go wrong?"
      - "Let's think about the worst case"

# Specialist Advisors (Auto-summoned by Keywords)
# These advisors are brought in when specific topics are detected.
specialists:
  - id: "specialist-1"
    name: "Domain Specialist"
    role: "Subject Matter Expert"
    emoji: "📚"
    color: "177"
    thinking_style: "Deep domain expertise, nuanced understanding"
    keywords:
      - technical
      - specialized
      - complex
    priorities:
      - Accuracy
      - Depth
      - Expertise

# Decision Domains
# Categories for organizing decisions made with this advisory board.
decision_domains:
  - strategy
  - operations
  - resources
  - technology
  - compliance

# Context Entity Types
# Domain-specific entity types for the Context Reasoning Format (CRF).
context_entities:
  - type: "{{.Domain}}-entity"
    display_name: "{{.DisplayName}} Entity"
    description: "A key entity in the {{.Domain}} domain"
    attributes:
      - name: "entity_type"
        type: "enum"
        enum_values:
          - type-a
          - type-b
          - type-c

# Plugin Settings
settings:
  default_mode: panel
  start_in_discovery: true
  max_advisors: 5
