# Plugin Settings - {{.Domain}}
# Domain-specific configuration and defaults

# Default interaction mode
# Options: panel, socratic, advocate, framework
default_mode: panel

# Default advisors to include in panel sessions
default_advisors:
  - expert-1
  - expert-2
  - expert-3

# Whether to start with the facilitator (discovery mode)
start_in_discovery: true

# Maximum advisors allowed in a single session
max_advisors: 5

# Auto-summon specialists based on keyword detection
auto_summon_specialists: true

# Custom domain-specific settings
# Add any domain-specific configuration here
custom:
  # Example: domain-specific thresholds, preferences, etc.
  # risk_threshold: high
  # decision_framework: default
